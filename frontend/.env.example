# Confidential ShadowPool - Environment Variables
# Copy this to .env.local and fill in the values

# The deployed fhEVM pool contract address
NEXT_PUBLIC_POOL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Chain ID (11155111 = Sepolia, 31337 = localhost)
NEXT_PUBLIC_CHAIN_ID=11155111

# RPC URL for the chain
NEXT_PUBLIC_RPC_URL=https://sepolia.infura.io/v3/your-infura-project-id

# Zama fhEVM Relayer URL (default: https://relayer.zama.ai)
NEXT_PUBLIC_RELAYER_URL=https://relayer.zama.ai
